# general settings
auto-reload yes
reload-time 120
reload-threads 4
download-retries 4
download-timeout 10
prepopulate-query-feeds yes
refresh-on-startup yes
max-items 500
always-display-description yes
podcast-auto-enqueue yes
save-path "~/Documents/SavedNews/"
cache-file "~/Documents/SavedNews/newsboat_cache.db"
#html-renderer "w3m -dump -T text/html"
#html-renderer "w3m -v -F -T text/html"
#pager "w3m -T text/html"

browser "w3m %u"
macro m set browser "mpv %u"; open-in-browser ; set browser "w3m %u"
macro f set browser "firefox %u"; open-in-browser ; set browser "w3m %u"

text-width 60 #https://baymard.com/blog/line-length-readability

# external browser
#browser "/usr/local/bin/w3m %u"
#browser "/usr/local/bin/w3m -v -F -T text/html %s"
#macro m set browser "/usr/local/bin/mpv %u"; open-in-browser ; set browser "/usr/local/bin/w3m %u"
#macro l set browser "/usr/local/bin/firefox %u"; open-in-browser ; set browser "/usr/local/bin/w3m %u"

# unbind keys
#unbind-key ENTER
unbind-key j
unbind-key k
unbind-key J
unbind-key K

# bind keys - vim style
#bind-key j down
#bind-key k up
goto-next-feed no

#browser "open -g -a 'Google Chrome' %u"

bind-key j down feedlist
bind-key k up feedlist
bind-key j next articlelist
bind-key k prev articlelist
bind-key J next-feed articlelist
bind-key K prev-feed articlelist
bind-key j down article
bind-key k up article
#bind-key l open
#bind-key h quit

# solarized
color background         default   default
color listnormal         default   default
color listnormal_unread  default   default
color listfocus          black     cyan
color listfocus_unread   black     cyan
color info               default   black
color article            default   default

# highlights
highlight article "^(Title):.*$" blue default
highlight article "https?://[^ ]+" red default
highlight article "\\[image\\ [0-9]+\\]" green default

feedlist-format     "%4i %n %12u %t"
articlelist-format  "%4i %f %D %?T?|%-17T| ?%t" 
#notify-format       "%d new articles (%n unread articles, %f unread feeds)"
#podlist-format      "%2i [%-5p %%] %-12S %F"

bookmark-cmd ~/.newsboat/bookmark.sh
bookmark-autopilot yes

unbind-key C feedlist
confirm-exit no
cleanup-on-quit no

#podboat
#max-downloads 2
#download-path="~/Documents/Music/"
#player="mp3blaster"

